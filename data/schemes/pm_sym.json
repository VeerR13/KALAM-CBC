  "prerequisites": ["pmjdy"],
  "benefit_summary": "\u20b93,000/month guaranteed pension after age 60. 50:50 govt-worker contribution. Contribution \u20b955-\u20b9200/month based on entry age. Spouse gets 50% family pension."
