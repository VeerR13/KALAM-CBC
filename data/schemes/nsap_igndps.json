{
  "scheme_id": "nsap_igndps",
  "name": "Disability Pension (IGNDPS)",
  "full_name": "Indira Gandhi National Disability Pension Scheme",
  "target_description": "BPL persons aged 18 and above with disability of 80% or more",
  "ministry": "Ministry of Rural Development",
  "data_source": "NSAP IGNDPS scheme details from nsap.nic.in and myscheme.gov.in",
  "data_freshness": "VERIFIED_AGAINST_PDF_2026-04-11",
  "rules": [
    {
      "rule_id": "NSAP-DPS-R01",
      "parameter": "age",
      "description": "Applicant must be at least 18 years old",
      "condition": {
        "type": "range_check",
        "field": "age",
        "min": 18
      },
      "is_mandatory": true,
      "weight": 20,
      "ambiguity_refs": [],
      "ambiguity_note": null
    },
    {
      "rule_id": "NSAP-DPS-R02",
      "parameter": "disability_severity",
      "description": "Applicant must have a disability of 80% or more as certified by a medical authority",
      "condition": {
        "type": "range_check",
        "field": "disability_percent",
        "min": 80,
        "max": 100
      },
      "is_mandatory": true,
      "weight": 35,
      "ambiguity_refs": [
        "AMB-22"
      ],
      "ambiguity_note": "40-79% disability excluded at central level — some states may have separate schemes for moderate disability"
    },
    {
      "rule_id": "NSAP-DPS-R03",
      "parameter": "bpl_status",
      "description": "Applicant must be from a BPL household",
      "condition": {
        "type": "field_check",
        "field": "has_ration_card",
        "values": [
          "AAY",
          "PHH"
        ],
        "ambiguous_values": [
          "unknown"
        ]
      },
      "is_mandatory": true,
      "weight": 30,
      "ambiguity_refs": [
        "AMB-17"
      ],
      "ambiguity_note": "BPL status based on SECC/ration card — stale data may exclude genuinely poor applicants"
    },
    {
      "rule_id": "NSAP-DPS-R04",
      "parameter": "aadhaar_bank",
      "description": "Must have Aadhaar for identity and DBT payment",
      "condition": {
        "type": "boolean_check",
        "field": "has_aadhaar",
        "equals": true
      },
      "is_mandatory": true,
      "weight": 15,
      "ambiguity_refs": [],
      "ambiguity_note": null
    }
  ],
  "required_documents": [
    {
      "document": "BPL Ration Card",
      "where_to_obtain": "PDS office",
      "processing_time_days": "1-7",
      "priority": 1
