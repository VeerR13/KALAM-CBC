        "type": "boolean_check",
        "field": "is_income_tax_payer",
        "equals": false
      },
      "is_mandatory": true,
      "weight": 30,
      "ambiguity_refs": [],
      "ambiguity_note": "From Oct 2022: income tax payers (current or former) NOT eligible."
    },
    {
      "rule_id": "APY-R04",
      "parameter": "not_epf_member",
