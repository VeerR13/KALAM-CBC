{
  "scheme_id": "nsap_ignwps",
  "name": "Widow Pension (IGNWPS)",
  "full_name": "Indira Gandhi National Widow Pension Scheme",
  "target_description": "Widows from BPL households aged 40 years and above",
  "ministry": "Ministry of Rural Development",
  "data_source": "NSAP IGNWPS scheme details from nsap.nic.in and myscheme.gov.in",
  "data_freshness": "VERIFIED_AGAINST_PDF_2026-04-11",
  "rules": [
    {
      "rule_id": "NSAP-WPS-R01",
      "parameter": "gender_widow",
      "description": "Applicant must be female",
      "condition": {
        "type": "field_check",
        "field": "gender",
        "values": ["F"],
        "ambiguous_values": []
      },
      "is_mandatory": true,
      "weight": 30,
      "ambiguity_refs": [],
      "ambiguity_note": null
    },
    {
      "rule_id": "NSAP-WPS-R02",
      "parameter": "marital_status_widow",
      "description": "Applicant must be a widow",
      "condition": {
        "type": "field_check",
        "field": "marital_status",
        "values": ["widowed"],
        "ambiguous_values": []
      },
      "is_mandatory": true,
      "weight": 30,
      "ambiguity_refs": [],
      "ambiguity_note": null
    },
    {
      "rule_id": "NSAP-WPS-R03",
      "parameter": "age",
      "description": "Applicant must be at least 40 years old",
      "condition": {
        "type": "range_check",
        "field": "age",
        "min": 40
      },
      "is_mandatory": true,
      "weight": 25,
      "ambiguity_refs": [],
      "ambiguity_note": null
    },
    {
      "rule_id": "NSAP-WPS-R04",
      "parameter": "bpl_status",
      "description": "Applicant must be from a BPL household",
      "condition": {
        "type": "field_check",
        "field": "has_ration_card",
        "values": ["AAY", "PHH"],
        "ambiguous_values": ["unknown"]
      },
      "is_mandatory": true,
      "weight": 25,
      "ambiguity_refs": ["AMB-17"],
      "ambiguity_note": "BPL status based on SECC/ration card — stale data may exclude genuinely poor applicants"
    },
    {
      "rule_id": "NSAP-WPS-R05",
      "parameter": "aadhaar_bank",
      "description": "Must have Aadhaar for identity and DBT payment",
      "condition": {
        "type": "boolean_check",
        "field": "has_aadhaar",
        "equals": true
      },
      "is_mandatory": true,
      "weight": 15,
      "ambiguity_refs": [],
      "ambiguity_note": null
    },
    {
      "rule_id": "NSAP-WPS-EX01",
      "parameter": "remarriage_exclusion",
      "description": "Pension discontinued on remarriage per central IGNWPS guidelines",
      "condition": {
        "type": "field_check",
        "field": "marital_status",
        "values": ["widowed"],
        "ambiguous_values": ["married", "divorced"]
      },
      "is_mandatory": true,
      "weight": 20,
      "ambiguity_refs": ["AMB-20"],
      "ambiguity_note": "PARTIALLY RESOLVED: Pension must be discontinued on remarriage — ambiguity around state-level discretion on enforcement"
    }
  ],
  "required_documents": [
    {
      "document": "Death Certificate of Husband",
      "where_to_obtain": "Municipality / Registrar",
      "processing_time_days": "7-15",
      "priority": 1
    },
    {
      "document": "BPL Ration Card",
      "where_to_obtain": "PDS office",
      "processing_time_days": "1-7",
      "priority": 2
    },
    {
      "document": "Age Proof",
      "where_to_obtain": "School / Medical Board",
      "processing_time_days": "0-7",
      "priority": 3
    },
    {
      "document": "Aadhaar Card",
      "where_to_obtain": "CSC / Post Office",
      "processing_time_days": "0",
      "priority": 4
    },
    {
      "document": "Bank Passbook",
      "where_to_obtain": "Any bank branch",
      "processing_time_days": "1-3",
      "priority": 5
    }
  ],
  "prerequisites": ["pmjdy"],
  "benefit_summary": "₹300/month (age 40-79), ₹500/month (age 80+). States add variable top-up."
}
